{
  "name": "3dmcp",
  "version": "0.1.0",
  "description": "MCP server that generates 3D-printable STL files from simple parametric primitives.",
  "type": "module",
  "bin": {
    "3dmcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "npm run build && node --test \"dist/**/*.test.js\""
  },
  "keywords": [
    "mcp",
    "stl",
    "3d-printing",
    "model-context-protocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
